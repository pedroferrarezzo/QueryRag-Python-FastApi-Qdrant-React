MINIO_ROOT_USER=ragadmin
MINIO_ROOT_PASSWORD=ragadmin
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=rag-documents
MINIO_SECURE=False

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents

BACKEND_PORT=8005
FRONTEND_PORT=80

GEMINI_API_KEY=xxxxxxxxxxxxxxxxx
GEMINI_LMM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

QUERY_RAG_FRONTEND_URL=http://localhost:${FRONTEND_PORT}

VITE_WS_CHAT_ENDPOINT=ws://localhost:${BACKEND_PORT}/rag/chat
VITE_API_ENDPOINT=http://localhost:${BACKEND_PORT}

# Dimensão dos vetores gerados pelo modelo de embedding
# A dimensão corresponde na prática a quantidade de índices do vetor de embedding
# https://ai.google.dev/gemini-api/docs/embeddings?hl=pt-br#control-embedding-size
EMBEDDING_DIMENSION=3072
# Quantidade máxima de chunks gerados por documento após o processamento
# Quando excedido, chunks adjacentes são mesclados para respeitar o limite
# Útil para controlar limites de lote (batch) e rate limiting em APIs de embedding
CHUNK_LIST_MAX_LENGTH=70